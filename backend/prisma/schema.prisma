// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── User ─────────────────────────────────────────────────────────────────────
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  username     String   @unique
  avatarUrl    String?
  userType     String   @default("REAL") // REAL|SIMULATED|GHOST
  rating       Int      @default(1000)
  xp           Int      @default(0)
  league       String   @default("bronze")
  referralCode String?
  isBanned     Boolean  @default(false)
  lastIp       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  matchPlayers MatchPlayer[]
  gameStats    UserGameStats[]
  invitesCreated Invite[]     @relation("InviteCreator")
  sentFriendships     Friendship[] @relation("FriendshipSender")
  receivedFriendships Friendship[] @relation("FriendshipReceiver")
  aiProfile           AIPlayerProfile?
  skillProfile        PlayerSkillProfile?
  ghostRuns           GhostRun[]

  @@index([rating])
  @@index([userType])
  @@map("users")
}

// ─── OTP ──────────────────────────────────────────────────────────────────────
model OTP {
  id        String   @id @default(uuid())
  email     String   @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("otps")
}

// ─── GameType ─────────────────────────────────────────────────────────────────
model GameType {
  id          String  @id
  name        String
  description String
  iconUrl     String?
  isActive    Boolean @default(true)
  displayOrder Int?

  matches Match[]

  @@map("game_types")
}

// ─── Match ────────────────────────────────────────────────────────────────────
model Match {
  id          String      @id @default(uuid())
  gameType    String
  level       Int         @default(1)
  status      String      @default("waiting") // waiting|countdown|active|finished
  isAI        Boolean     @default(false)
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime    @default(now())

  gameTypeRef GameType?   @relation(fields: [gameType], references: [id])
  players     MatchPlayer[]
  invites     Invite[]

  @@index([gameType, level, status])
  @@map("matches")
}

// ─── MatchPlayer ──────────────────────────────────────────────────────────────
model MatchPlayer {
  id              String    @id @default(uuid())
  matchId         String
  userId          String
  score           Int       @default(0)
  correctAnswers  Int       @default(0)
  mistakes        Int       @default(0)
  xpGained        Int       @default(0)
  eloChange       Int       @default(0)
  position        Int?
  isFirstFinisher Boolean   @default(false)
  finishedAt      DateTime?
  createdAt       DateTime  @default(now())

  match Match @relation(fields: [matchId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([matchId, userId])
  @@map("match_players")
}

// ─── Invite ───────────────────────────────────────────────────────────────────
model Invite {
  id        String   @id @default(uuid())
  code      String   @unique
  matchId   String?
  gameType  String
  level     Int      @default(1)
  createdBy String
  expiresAt DateTime
  maxUses   Int      @default(1)
  usedBy    String   @default("[]")
  createdAt DateTime @default(now())

  creator User   @relation("InviteCreator", fields: [createdBy], references: [id])
  match   Match? @relation(fields: [matchId], references: [id])

  @@map("invites")
}

// ─── UserGameStats ────────────────────────────────────────────────────────────
model UserGameStats {
  id            String   @id @default(uuid())
  userId        String
  gameType      String
  level         Int
  totalMatches  Int      @default(0)
  wins          Int      @default(0)
  losses        Int      @default(0)
  draws         Int      @default(0)
  totalScore    Int      @default(0)
  bestScore     Int      @default(0)
  avgScore      Float    @default(0)
  currentStreak Int      @default(0)
  bestStreak    Int      @default(0)
  eloHistory    String   @default("[]")
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, gameType, level], name: "userId_gameType_level")
  @@map("user_game_stats")
}

// ─── Admin ────────────────────────────────────────────────────────────────────
model Admin {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  @@map("admins")
}

// ─── Season ───────────────────────────────────────────────────────────────────
model Season {
  id        String   @id @default(uuid())
  name      String
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("seasons")
}

// ─── Friendship ───────────────────────────────────────────────────────────────
model Friendship {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  status     String   @default("pending") // pending|accepted|declined
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sender   User @relation("FriendshipSender",   fields: [senderId],   references: [id])
  receiver User @relation("FriendshipReceiver", fields: [receiverId], references: [id])

  @@unique([senderId, receiverId])
  @@map("friendships")
}

// ─── AIPlayerProfile ─────────────────────────────────────────────────────────
model AIPlayerProfile {
  id                    String   @id @default(uuid())
  userId                String   @unique
  skillLevel            Int      @default(5)
  thinkingSpeedMsMin    Int      @default(2500)
  thinkingSpeedMsMax    Int      @default(6000)
  mistakeRate           Float    @default(0.12)
  hesitationProbability Float    @default(0.18)
  correctionProbability Float    @default(0.35)
  playStyle             String   @default("balanced")
  personality           String   @default("CASUAL_PLAYER")
  preferredGames        String   @default("[]") // JSON string of gameSlug[]
  onlineProbability     Float    @default(0.35)
  chatProbability       Float    @default(0.06)
  sessionLengthMin      Int      @default(8)
  sessionLengthMax      Int      @default(25)
  activityPattern       String   @default("{}") // JSON string
  enabled               Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([enabled])
  @@index([skillLevel])
  @@map("ai_player_profiles")
}

// ─── PlayerSkillProfile ──────────────────────────────────────────────────────
model PlayerSkillProfile {
  id                    String   @id @default(uuid())
  userId                String   @unique
  averageCompletionTime Float    @default(0)
  mistakeRate           Float    @default(0)
  successRate           Float    @default(0)
  preferredGameTypes    String   @default("[]") // JSON string of gameSlug[]
  winLossRatio          Float    @default(1)
  hintUsageRate         Float    @default(0)
  correctionRate        Float    @default(0)
  pathEfficiency        Float    @default(0)
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("player_skill_profiles")
}

// ─── GhostRun ────────────────────────────────────────────────────────────────
model GhostRun {
  id             String   @id @default(uuid())
  playerId       String
  gameType       String
  difficulty     Int      @default(1)
  moves          String   @default("[]") // JSON string
  timestamps     String   @default("[]") // JSON string
  mistakes       Int      @default(0)
  corrections    Int      @default(0)
  completionTime Float    @default(0)
  finalScore     Int      @default(0)
  createdAt      DateTime @default(now())

  player User @relation(fields: [playerId], references: [id])

  @@index([playerId, gameType])
  @@index([createdAt])
  @@map("ghost_runs")
}

// ─── BotConfig ───────────────────────────────────────────────────────────────
model BotConfig {
  id                  String   @id @default(uuid())
  enabled             Boolean  @default(false)
  maxBotsOnline       Int      @default(6)
  botScoreLimit       Int      @default(5000)
  activityFeedEnabled Boolean  @default(false)
  chatEnabled         Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("bot_config")
}

// ─── SystemConfig ─────────────────────────────────────────────────────────────
// Stochează parametri globali editabili din admin (ELO, XP, ligi).
// key: 'elo' | 'xp' | 'league'  — value: JSON string cu câmpurile respective.
// Câmpurile lipsă = folosesc default-urile din cod (shared/).
model SystemConfig {
  key       String   @id
  value     String   // JSON string
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_configs")
}

// ─── GameScoringConfig ────────────────────────────────────────────────────────
// Suprascrie regulile de scoring din cod pentru un joc + nivel specific.
// level = null înseamnă: se aplică la toate nivelele jocului (override de bază).
// level = N: override specific pentru nivelul N (ia prioritate față de cel cu level=null).
// Câmpurile null înseamnă "folosește default-ul din cod".
// Modificările NU afectează meciurile deja jucate (scorurile sunt salvate la final de meci).
model GameScoringConfig {
  id                 String   @id @default(uuid())
  gameType           String
  level              Int?     // null = toate nivelele
  pointsPerCorrect   Int?
  pointsPerMistake   Int?
  bonusFirstFinisher Int?
  bonusCompletion    Int?
  timeLimitSeconds   Int?
  forfeitBonus       Int?
  updatedBy          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([gameType, level], name: "gameType_level")
  @@index([gameType])
  @@map("game_scoring_configs")
}

// ─── BannedIP ─────────────────────────────────────────────────────────────────
model BannedIP {
  id           String   @id @default(uuid())
  ip           String   @unique
  reason       String   @default("ban_user")
  bannedUserId String?
  createdAt    DateTime @default(now())

  @@map("banned_ips")
}
